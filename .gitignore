# SearXNG .gitignore
# Synced with .dockerignore & pyrightconfig.json

# ============================================================
# Python bytecode and cache files
# ============================================================
*.pyc
*/*.pyc
*.pyo
__pycache__/
*~
*.swp
*.swo
*~.nib

# Python coverage
.coverage
coverage/
htmlcov/
.coverage.*

# ============================================================
# Build and distribution artifacts
# ============================================================
.cache/
build/
dist/
*.egg-info/
*.egg
.eggs/
*.whl

# ============================================================
# Virtual environments and local installs
# ============================================================
.venv/
venv/
ENV/
env/
local/
.pytest_cache/
.mypy_cache/

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.nvm/

# ============================================================
# Go
# ============================================================
.govm/

# ============================================================
# Data and runtime files (may contain sensitive info)
# ============================================================
data/*.db
data/*.db.lock
data/*.sqlite
data/*.sqlite3
data/*.milvus
data/*.json.bak

# ============================================================
# Secrets, credentials and environment files
# Note: searx/settings.yml is tracked in the repo; use settings-user.yml for local overrides
.env
.env.*
!.env.example
*.env
searx/settings-user.yml
searx/settings-user.yaml
searx/settings-local.yml
searx/settings-local.yaml
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.jks
credentials.json
credentials.yml
secrets/
*.token
*.apikey

# ============================================================
# IDE and editor files
# ============================================================
.idea/
.vscode/*.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
.dir-locals.el

# ============================================================
# Generated/frozen files
# ============================================================
searx/version_frozen.py

# ============================================================
# Documentation and deployment
# ============================================================
gh-pages/

# ============================================================
# OS and temporary files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.tmp
*.temp

# ============================================================
# Client
# ============================================================
client/simple/node_modules/
client/simple/dist/
client/simple/build/

# ============================================================
# Logs
# ============================================================
*.log
logs/
